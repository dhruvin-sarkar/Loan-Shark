# Auto-detect text files and normalize line endings
* text=auto eol=lf

# GDScript
*.gd text eol=lf diff=gdscript
*.tscn text eol=lf
*.tres text eol=lf
*.godot text eol=lf
*.import text eol=lf
*.cfg text eol=lf
*.md text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.glsl text eol=lf
*.shader text eol=lf

# Binary assets — tell Git not to diff or merge these
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.svg binary
*.ico binary
*.ttf binary
*.otf binary
*.wav binary
*.ogg binary
*.mp3 binary
*.mp4 binary
*.webm binary
*.pck binary
*.wasm binary
*.zip binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# Force linguist to show GDScript as the main language on GitHub
# (this is what fixes your Objective-C problem)
*.gd linguist-language=GDScript linguist-detectable=true
*.tscn linguist-language=GDScript linguist-detectable=true
*.tres linguist-detectable=false
*.import linguist-detectable=false
*.cfg linguist-detectable=false
export_presets.cfg linguist-detectable=false